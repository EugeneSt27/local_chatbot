{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Запуск Локального AI Assistant\n",
    "Этот блокнот позволяет запустить выбранный бэкенд (vLLM или Ollama) и UI прямо внутри вашей Jupyter среды."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess\n",
    "import time\n",
    "import sys\n",
    "import os\n",
    "import config\n",
    "\n",
    "engine = config.ENGINE\n",
    "model_path_or_name = config.MODEL_PATH_OR_NAME\n",
    "port = config.PORT\n",
    "\n",
    "print(f\"Инициализация бэкенда '{engine}' на порте {port} для модели '{model_path_or_name}'...\")\n",
    "\n",
    "# Запускаем сервер в фоновом режиме через наш скрипт\n",
    "backend_process = subprocess.Popen(\n",
    "    [sys.executable, \"start_backend.py\"],\n",
    "    stdout=subprocess.PIPE,\n",
    "    stderr=subprocess.STDOUT,\n",
    "    text=True\n",
    ")\n",
    "\n",
    "print(\"Ждем начала работы сервера (около 15 секунд)...\")\n",
    "time.sleep(15)\n",
    "print(\"Бэкенд готов!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Запуск Streamlit UI...\")\n",
    "streamlit_process = subprocess.Popen(\n",
    "    [sys.executable, \"-m\", \"streamlit\", \"run\", \"app.py\"]\n",
    ")\n",
    "print(\"UI должен открыться в новой вкладке браузера (по умолчанию http://localhost:8501).\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Остановка работы\n",
    "Выполните нижнюю ячейку, когда закончите работу. Это закроет фоновые процессы."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "try:\n",
    "    backend_process.terminate()\n",
    "    streamlit_process.terminate()\n",
    "    print(\"Все процессы успешно завершены.\")\n",
    "except:\n",
    "    print(\"Процессы уже были завершены.\")"
   ]
  }
 ],
