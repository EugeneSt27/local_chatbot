@echo off
chcp 65001 >nul
echo ========================================================
echo Начинается запуск локального AI-ассистента
echo ========================================================

echo 1. Запуск бэкенда vLLM... (откроется в новом свернутом окне)
:: Запуск через Python-обертку, чтобы гарантированно избежать проблем с отступами и путями в путях Windows
start /min "vLLM Server" cmd /c "python start_backend.py && pause"

echo 2. Ожидание инициализации модели в GPU... 
echo Пожалуйста, подождите 15-20 секунд (в зависимости от скорости диска).
timeout /t 15

echo 3. Запуск пользовательского интерфейса (Streamlit)...
start /b "Streamlit UI" cmd /c "streamlit run app.py"

echo ========================================================
echo Готово! Интерфейс автоматически откроется в браузере.
echo Чтобы остановить работу чат-бота, закройте окно интерфейса и свернутое окно "vLLM Server".
echo ========================================================
pause
